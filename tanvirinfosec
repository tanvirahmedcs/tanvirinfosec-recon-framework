#!/bin/bash

# ----------------------------------------
#  TANVIR INFOSEC RECON PIPELINE (macOS)
#  Authorized testing only
# ----------------------------------------

# Colors
RED="\033[1;31m"
GREEN="\033[1;32m"
YELLOW="\033[1;33m"
BLUE="\033[1;34m"
CYAN="\033[1;36m"
RESET="\033[0m"

BASE_DIR="$HOME/reconn/TANVIRAHMEDCS"
GOBIN="$(go env GOPATH 2>/dev/null)/bin"

# -----------------------------
#  Helpers
# -----------------------------
section() {
  echo -e "\n${BLUE}========== $1 ==========${RESET}\n"
}

progress() {
  echo -e "${CYAN}[$1]${RESET} $2"
}

has_cmd() {
  command -v "$1" &>/dev/null || [ -x "$GOBIN/$1" ]
}

ensure_brew() {
  if ! command -v brew &>/dev/null; then
    echo -e "${RED}[!] Homebrew not found. Install from https://brew.sh first.${RESET}"
    exit 1
  fi
}

# -----------------------------
#  Tool install/update mapping
# -----------------------------
brew_tools=(
  "nmap"
  "massdns"
  "naabu"
  "theharvester"
  "shodan"
  "ffuf"
  "gobuster"
  "sqlmap"
)

go_tools=(
  "subfinder"
  "amass"
  "dnsx"
  "httpx"
  "gau"
  "waybackurls"
  "hakrawler"
  "katana"
  "nuclei"
  "dalfox"
  "Gxss"
  "qsreplace"
  "anew"
  "notify"
  "gowitness"
)

go_install_cmd() {
  case "$1" in
    subfinder) echo "github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest" ;;
    amass) echo "github.com/owasp-amass/amass/v4/...@latest" ;;
    dnsx) echo "github.com/projectdiscovery/dnsx/cmd/dnsx@latest" ;;
    httpx) echo "github.com/projectdiscovery/httpx/cmd/httpx@latest" ;;
    gau) echo "github.com/lc/gau/v2/cmd/gau@latest" ;;
    waybackurls) echo "github.com/tomnomnom/waybackurls@latest" ;;
    hakrawler) echo "github.com/hakluke/hakrawler@latest" ;;
    katana) echo "github.com/projectdiscovery/katana/cmd/katana@latest" ;;
    nuclei) echo "github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest" ;;
    dalfox) echo "github.com/hahwul/dalfox/v2@latest" ;;
    Gxss) echo "github.com/KathanP19/Gxss@latest" ;;
    qsreplace) echo "github.com/tomnomnom/qsreplace@latest" ;;
    anew) echo "github.com/tomnomnom/anew@latest" ;;
    notify) echo "github.com/projectdiscovery/notify/cmd/notify@latest" ;;
    gowitness) echo "github.com/sensepost/gowitness@latest" ;;
    *) echo "" ;;
  esac
}

ensure_brew_tool() {
  local t="$1"
  if has_cmd "$t"; then
    echo -e "${GREEN}[OK]${RESET} $t"
  else
    echo -e "${YELLOW}[INSTALL]${RESET} brew install $t"
    brew install "$t"
  fi
}

ensure_go_tool() {
  local t="$1"
  local pkg
  pkg=$(go_install_cmd "$t")
  [ -z "$pkg" ] && return
  if has_cmd "$t"; then
    echo -e "${GREEN}[OK]${RESET} $t"
  else
    echo -e "${YELLOW}[INSTALL]${RESET} go install $pkg"
    go install "$pkg"
  fi
}

update_tools() {
  section "Updating tools (brew + go)"
  ensure_brew
  echo -e "${YELLOW}[*] brew upgrade (may take time)...${RESET}"
  brew upgrade >/dev/null 2>&1 &
  BREW_PID=$!

  echo -e "${YELLOW}[*] go-based tools update...${RESET}"
  for t in "${go_tools[@]}"; do
    pkg=$(go_install_cmd "$t")
    [ -z "$pkg" ] && continue
    echo -e "${CYAN}[-] go install $pkg${RESET}"
    go install "$pkg" >/dev/null 2>&1
  done

  wait $BREW_PID 2>/dev/null
  echo -e "${GREEN}[+] Tool update phase finished.${RESET}"

  if has_cmd nuclei; then
    echo -e "${YELLOW}[*] Updating nuclei templates...${RESET}"
    nuclei -update-templates >/dev/null 2>&1
  fi
}

# -----------------------------
#  Args
# -----------------------------
DOMAIN=""
NO_UPDATE=0

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    -d|--domain) DOMAIN="$2"; shift ;;
    --no-update) NO_UPDATE=1 ;;
  esac
  shift
done

if [[ -z "$DOMAIN" ]]; then
  echo -e "${RED}Usage:${RESET} tanvirinfosec -d example.com [--no-update]"
  exit 1
fi

# -----------------------------
#  Workspace
# -----------------------------
TARGET_DIR="$BASE_DIR/$DOMAIN"
mkdir -p "$TARGET_DIR"/{subdomains,urls,js,parameters,xss,nuclei,screenshots,logs}
LOG_FILE="$TARGET_DIR/logs/pipeline.log"
SUMMARY_FILE="$TARGET_DIR/report-summary.txt"

echo -e "${GREEN}[+] Workspace:${RESET} $TARGET_DIR"
echo -e "${GREEN}[+] Log file:${RESET} $LOG_FILE"

# -----------------------------
#  Tool checks
# -----------------------------
section "Tool checks"

ensure_brew

echo -e "${CYAN}[*] Ensuring brew tools...${RESET}"
for t in "${brew_tools[@]}"; do
  ensure_brew_tool "$t"
done

echo -e "${CYAN}[*] Ensuring go tools...${RESET}"
for t in "${go_tools[@]}"; do
  ensure_go_tool "$t"
done

if [[ $NO_UPDATE -eq 0 ]]; then
  update_tools
else
  echo -e "${YELLOW}[!] Skipping auto-update (--no-update set).${RESET}"
fi

# -----------------------------
#  STEP 1 — Passive subdomains
# -----------------------------
section "Step 1/9 - Passive subdomains"
SUB_PASSIVE="$TARGET_DIR/subdomains/passive.txt"

progress "1.1" "subfinder"
subfinder -d "$DOMAIN" -all -silent | anew "$SUB_PASSIVE" 2>>"$LOG_FILE"

progress "1.2" "amass (passive)"
amass enum -passive -d "$DOMAIN" -o "$TARGET_DIR/subdomains/amass.txt" 2>>"$LOG_FILE"
cat "$TARGET_DIR/subdomains/amass.txt" | anew "$SUB_PASSIVE" 2>>"$LOG_FILE"

# -----------------------------
#  STEP 2 — Active resolution
# -----------------------------
section "Step 2/9 - Active resolution"
SUB_RESOLVED="$TARGET_DIR/subdomains/resolved.txt"

cat "$SUB_PASSIVE" | dnsx -silent -resp-only -o "$SUB_RESOLVED" 2>>"$LOG_FILE"

# -----------------------------
#  STEP 3 — Port scanning (surface)
# -----------------------------
section "Step 3/9 - Port scanning"
PORTS_FILE="$TARGET_DIR/dns-ports.txt"

cat "$SUB_RESOLVED" | naabu -silent -top-ports 100 -o "$PORTS_FILE" 2>>"$LOG_FILE"

# -----------------------------
#  STEP 4 — URL collection
# -----------------------------
section "Step 4/9 - URL collection"
mkdir -p "$TARGET_DIR/urls"
URLS_RAW="$TARGET_DIR/urls/raw_urls.txt"
URLS_CLEAN="$TARGET_DIR/urls/clean_urls.txt"

progress "4.1" "gau"
cat "$SUB_RESOLVED" | gau --o "$URLS_RAW" 2>>"$LOG_FILE"

progress "4.2" "waybackurls"
cat "$SUB_RESOLVED" | waybackurls >> "$URLS_RAW" 2>>"$LOG_FILE"

sort -u "$URLS_RAW" > "$URLS_CLEAN"

# -----------------------------
#  STEP 5 — JS discovery
# -----------------------------
section "Step 5/9 - JS discovery"
mkdir -p "$TARGET_DIR/js"
JS_FILES="$TARGET_DIR/js/js_files.txt"

if has_cmd subjs; then
  progress "5.1" "subjs"
  cat "$SUB_RESOLVED" | subjs | anew "$JS_FILES" 2>>"$LOG_FILE"
fi

# -----------------------------
#  STEP 6 — Parameters (for IDOR/XSS/SQLi/CSRF)
# -----------------------------
section "Step 6/9 - Parameter discovery"
mkdir -p "$TARGET_DIR/parameters"
PARAMS_FILE="$TARGET_DIR/parameters/params.txt"

grep -Eo '\?[^ ]+' "$URLS_CLEAN" 2>/dev/null | sed 's/^?//' | tr '&' '\n' | cut -d'=' -f1 | sort -u > "$PARAMS_FILE"

# -----------------------------
#  STEP 7 — XSS candidates (surface)
# -----------------------------
section "Step 7/9 - XSS candidates"
mkdir -p "$TARGET_DIR/xss"
XSS_CANDIDATES="$TARGET_DIR/xss/xss_candidates.txt"

if has_cmd Gxss; then
  progress "7.1" "Gxss"
  cat "$URLS_CLEAN" | Gxss -c 100 -p Xss | anew "$XSS_CANDIDATES" 2>>"$LOG_FILE"
fi

if has_cmd dalfox; then
  progress "7.2" "dalfox (you can tune this later)"
  # Example (commented for safety; you decide when/how to run):
  # cat "$XSS_CANDIDATES" | dalfox pipe -o "$TARGET_DIR/xss/dalfox.txt" 2>>"$LOG_FILE"
fi

# -----------------------------
#  STEP 8 — Nuclei scanning (generic vulns)
# -----------------------------
section "Step 8/9 - Nuclei scanning"
mkdir -p "$TARGET_DIR/nuclei"
NUCLEI_OUT="$TARGET_DIR/nuclei/findings.txt"
NUCLEI_JSON="$TARGET_DIR/nuclei/findings.json"

if has_cmd httpx; then
  progress "8.1" "httpx (HTTP surface)"
  cat "$SUB_RESOLVED" | httpx -silent -status-code -title -json -o "$TARGET_DIR/urls/httpx.json" 2>>"$LOG_FILE"
fi

progress "8.2" "nuclei"
nuclei -l "$SUB_RESOLVED" -json -o "$NUCLEI_JSON" 2>>"$LOG_FILE"
# Also keep a plain text version for quick view
nuclei -l "$SUB_RESOLVED" -o "$NUCLEI_OUT" 2>>"$LOG_FILE"

# -----------------------------
#  STEP 9 — Screenshots (visual)
# -----------------------------
section "Step 9/9 - Screenshots"
if has_cmd gowitness; then
  gowitness file -f "$SUB_RESOLVED" -P "$TARGET_DIR/screenshots" --no-http 2>>"$LOG_FILE"
fi

# -----------------------------
#  Severity summary (low/medium/high/critical)
#  Based on nuclei JSON output
# -----------------------------
section "Severity summary"

LOW=0
MEDIUM=0
HIGH=0
CRITICAL=0

if [ -s "$NUCLEI_JSON" ]; then
  LOW=$(grep -i '"severity":"low"' "$NUCLEI_JSON" | wc -l | tr -d ' ')
  MEDIUM=$(grep -i '"severity":"medium"' "$NUCLEI_JSON" | wc -l | tr -d ' ')
  HIGH=$(grep -i '"severity":"high"' "$NUCLEI_JSON" | wc -l | tr -d ' ')
  CRITICAL=$(grep -i '"severity":"critical"' "$NUCLEI_JSON" | wc -l | tr -d ' ')
fi

# -----------------------------
#  Final report
# -----------------------------
{
  echo "Recon Summary for $DOMAIN"
  echo "Generated on: $(date)"
  echo ""
  echo "Workspace: $TARGET_DIR"
  echo ""
  echo "Subdomains (passive): $(wc -l < "$SUB_PASSIVE" 2>/dev/null || echo 0)"
  echo "Subdomains (resolved): $(wc -l < "$SUB_RESOLVED" 2>/dev/null || echo 0)"
  echo "Ports (naabu top-100): $(wc -l < "$PORTS_FILE" 2>/dev/null || echo 0)"
  echo "URLs (clean): $(wc -l < "$URLS_CLEAN" 2>/dev/null || echo 0)"
  echo "JS files: $(wc -l < "$JS_FILES" 2>/dev/null || echo 0)"
  echo "Parameters: $(wc -l < "$PARAMS_FILE" 2>/dev/null || echo 0)"
  echo "XSS candidates (Gxss): $(wc -l < "$XSS_CANDIDATES" 2>/dev/null || echo 0)"
  echo ""
  echo "Nuclei findings by severity:"
  echo "  Low:      $LOW"
  echo "  Medium:   $MEDIUM"
  echo "  High:     $HIGH"
  echo "  Critical: $CRITICAL"
  echo ""
  echo "Next manual focus areas (based on your style):"
  echo "  - IDOR / Broken Access Control on authenticated endpoints"
  echo "  - Client-side JS logic (JS files + httpx titles)"
  echo "  - XSS on high-value parameters"
  echo "  - SQLi on interesting parameters / forms"
  echo "  - Open redirects, CSRF, upload flows, LFI/RCE (manual review)"
} > "$SUMMARY_FILE"

echo -e "${GREEN}[+] Summary saved:${RESET} $SUMMARY_FILE"
echo -e "${GREEN}[+] Done for domain:${RESET} $DOMAIN"
# ----------------------------------------
#  PRETTY MARKDOWN REPORT GENERATION
# ----------------------------------------

REPORT_MD="$TARGET_DIR/report.md"

echo "# 🛡️ Tanvir Infosec Recon Report" > "$REPORT_MD"
echo "### Target: **$DOMAIN**" >> "$REPORT_MD"
echo "Generated: $(date)" >> "$REPORT_MD"
echo "" >> "$REPORT_MD"

echo "## 📌 Summary" >> "$REPORT_MD"
echo "- Passive Subdomains: **$(wc -l < "$SUB_PASSIVE" 2>/dev/null || echo 0)**" >> "$REPORT_MD"
echo "- Resolved Subdomains: **$(wc -l < "$SUB_RESOLVED" 2>/dev/null || echo 0)**" >> "$REPORT_MD"
echo "- URLs Collected: **$(wc -l < "$URLS_CLEAN" 2>/dev/null || echo 0)**" >> "$REPORT_MD"
echo "- JavaScript Files: **$(wc -l < "$JS_FILES" 2>/dev/null || echo 0)**" >> "$REPORT_MD"
echo "- Parameters Identified: **$(wc -l < "$PARAMS_FILE" 2>/dev/null || echo 0)**" >> "$REPORT_MD"
echo "- XSS Candidates: **$(wc -l < "$XSS_CANDIDATES" 2>/dev/null || echo 0)**" >> "$REPORT_MD"
echo "" >> "$REPORT_MD"

echo "## 🚨 Severity Breakdown (From Nuclei)" >> "$REPORT_MD"
echo "- 🟢 Low: **$LOW**" >> "$REPORT_MD"
echo "- 🟡 Medium: **$MEDIUM**" >> "$REPORT_MD"
echo "- 🔥 High: **$HIGH**" >> "$REPORT_MD"
echo "- 🛑 Critical: **$CRITICAL**" >> "$REPORT_MD"
echo "" >> "$REPORT_MD"

echo "## 🗂️ Subdomains" >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
cat "$SUB_RESOLVED" >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
echo "" >> "$REPORT_MD"

echo "## 🌐 URLs" >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
cat "$URLS_CLEAN" | head -n 200 >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
echo "_Showing first 200 for readability_" >> "$REPORT_MD"
echo "" >> "$REPORT_MD"

echo "## 📜 JavaScript Files" >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
cat "$JS_FILES" >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
echo "" >> "$REPORT_MD"

echo "## 🧩 Parameters (Useful for IDOR, XSS, SQLi, CSRF)" >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
cat "$PARAMS_FILE" >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
echo "" >> "$REPORT_MD"

echo "## 🔍 XSS Candidates" >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
cat "$XSS_CANDIDATES" >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
echo "" >> "$REPORT_MD"

echo "## 🧪 Nuclei Findings (Raw)" >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
cat "$NUCLEI_OUT" >> "$REPORT_MD"
echo '```' >> "$REPORT_MD"
echo "" >> "$REPORT_MD"

echo "## 🏷️ Custom Tags (Manual Analyst Notes)" >> "$REPORT_MD"
echo "Use these tags to classify findings during manual review:" >> "$REPORT_MD"
echo "" >> "$REPORT_MD"

echo "- **IDOR** → Insecure Direct Object Reference" >> "$REPORT_MD"
echo "- **BAC** → Broken Access Control" >> "$REPORT_MD"
echo "- **CSRF** → Cross-Site Request Forgery" >> "$REPORT_MD"
echo "- **XSS** → Cross-Site Scripting" >> "$REPORT_MD"
echo "- **SQLi** → SQL Injection" >> "$REPORT_MD"
echo "- **LFI** → Local File Inclusion" >> "$REPORT_MD"
echo "- **RCE** → Remote Code Execution" >> "$REPORT_MD"
echo "- **OR** → Open Redirect" >> "$REPORT_MD"
echo "- **UPLOAD** → File Upload / Deface Vector" >> "$REPORT_MD"
echo "- **API** → API Endpoint / Logic" >> "$REPORT_MD"
echo "- **JS** → JavaScript Logic / Sensitive Keys" >> "$REPORT_MD"
echo "- **HTML/CSS** → Client-side UI/DOM issues" >> "$REPORT_MD"
echo "" >> "$REPORT_MD"

echo "## 📝 Manual Finding Template (Copy/Paste)" >> "$REPORT_MD"
cat << 'EOF' >> "$REPORT_MD"

---

# 🔐 Finding Title (e.g., IDOR in /api/v1/user/profile)

**Severity:** High  
**Category:** IDOR / BAC / CSRF / XSS / SQLi / LFI / RCE / OR / UPLOAD / API / JS  
**Status:** Unconfirmed / Confirmed  
**Endpoint:**  
